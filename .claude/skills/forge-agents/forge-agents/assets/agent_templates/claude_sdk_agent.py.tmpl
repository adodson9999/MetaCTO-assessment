# Claude Agent SDK agent — template. Standalone program mirroring the other three.
# Gated prompt fills SYSTEM_PROMPT. Emits results/runs/<run-id>/claude_sdk.json.
# Native Claude by default; Ollama reachable via the LiteLLM proxy if provider=ollama.
import json, os, sys, asyncio
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(os.environ.get("FORGE_WORKSPACE", ".")) / ".." / "scripts"))
import backend_config  # noqa: E402

WORKSPACE = Path(os.environ.get("FORGE_WORKSPACE", "."))
RUN_ID = os.environ.get("FORGE_RUN_ID", "manual")
AGENT = "claude_sdk"

SYSTEM_PROMPT = """<<< paste claude_sdk.prompt.md (debate-gated, approved lines only) >>>"""


async def run() -> str:
    spec = backend_config.resolve(WORKSPACE)
    task = (WORKSPACE / "task_spec.md").read_text()
    try:
        from claude_agent_sdk import query, ClaudeAgentOptions
        opts = ClaudeAgentOptions(system_prompt=SYSTEM_PROMPT, model=spec["native"]["model"])
        chunks = []
        async for msg in query(prompt=task, options=opts):
            chunks.append(getattr(msg, "content", str(msg)))
        return "".join(map(str, chunks))
    except Exception as e:
        # Fallback to OpenAI-compatible path (e.g., Ollama or LiteLLM proxy)
        import urllib.request
        body = json.dumps({"model": spec["model"],
                           "messages": [{"role": "system", "content": SYSTEM_PROMPT},
                                        {"role": "user", "content": task}]}).encode()
        req = urllib.request.Request(spec["base_url"] + "/chat/completions",
                                     data=body, headers={"Content-Type": "application/json"})
        with urllib.request.urlopen(req) as r:
            data = json.loads(r.read())
        return data["choices"][0]["message"]["content"]


def emit(metric_value: float, raw_output_path: str):
    metric = json.loads((WORKSPACE / "judge" / "metric.json").read_text())
    out = WORKSPACE / "results" / "runs" / RUN_ID / f"{AGENT}.json"
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps({
        "agent": AGENT, "run_id": RUN_ID,
        "metric_name": metric["metric_name"], "metric_value": metric_value,
        "raw_output_path": raw_output_path,
        "ts": datetime.now(timezone.utc).isoformat(),
    }, indent=2))


if __name__ == "__main__":
    output = asyncio.run(run())
    raw = WORKSPACE / "results" / "runs" / RUN_ID / f"{AGENT}.out.txt"
    raw.parent.mkdir(parents=True, exist_ok=True)
    raw.write_text(output)
    emit(0.0, str(raw))
