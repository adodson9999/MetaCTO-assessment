# CrewAI agent — template. Gated prompt fills BACKSTORY/GOAL.
# Emits results/runs/<run-id>/crewai.json. CrewAI routes models via LiteLLM,
# so Ollama and Claude Haiku both work through the central backend config.
import json, os, sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(os.environ.get("FORGE_WORKSPACE", ".")) / ".." / "scripts"))
import backend_config  # noqa: E402

WORKSPACE = Path(os.environ.get("FORGE_WORKSPACE", "."))
RUN_ID = os.environ.get("FORGE_RUN_ID", "manual")
AGENT = "crewai"

GOAL = """<<< paste crewai.prompt.md goal lines (debate-gated) >>>"""
BACKSTORY = """<<< paste crewai.prompt.md backstory/system lines (debate-gated) >>>"""


def _llm_string():
    spec = backend_config.resolve(WORKSPACE)
    # LiteLLM model strings: "ollama/<model>" or "anthropic/<model>"
    if spec["native"]["kind"] == "anthropic":
        return f"anthropic/{spec['native']['model']}"
    return f"ollama/{spec['native']['model']}"


def run():
    from crewai import Agent, Task, Crew

    worker = Agent(role="task-agent", goal=GOAL, backstory=BACKSTORY,
                   llm=_llm_string(), verbose=False)
    task_text = (WORKSPACE / "task_spec.md").read_text()
    task = Task(description=task_text, agent=worker,
                expected_output="the task result")
    crew = Crew(agents=[worker], tasks=[task], verbose=False)
    result = crew.kickoff()
    return str(result)


def emit(metric_value: float, raw_output_path: str):
    metric = json.loads((WORKSPACE / "judge" / "metric.json").read_text())
    out = WORKSPACE / "results" / "runs" / RUN_ID / f"{AGENT}.json"
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps({
        "agent": AGENT, "run_id": RUN_ID,
        "metric_name": metric["metric_name"], "metric_value": metric_value,
        "raw_output_path": raw_output_path,
        "ts": datetime.now(timezone.utc).isoformat(),
    }, indent=2))


if __name__ == "__main__":
    output = run()
    raw = WORKSPACE / "results" / "runs" / RUN_ID / f"{AGENT}.out.txt"
    raw.parent.mkdir(parents=True, exist_ok=True)
    raw.write_text(output)
    emit(0.0, str(raw))
