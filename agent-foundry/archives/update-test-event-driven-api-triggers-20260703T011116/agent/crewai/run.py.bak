#!/usr/bin/env python3
"""CrewAI event-trigger-testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-topic Task.
CrewAI routes the model through LiteLLM, so claude-haiku works via an "anthropic/<model>"
string and the air-gapped default works via "ollama/<model>". Deterministic execution
(publish to the local substrate, poll state, read log + DLQ at real timing), recording,
and emit are the shared harness's job (agents/common/eventdriven.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import eventdriven  # noqa: E402
from eventdriven_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API event-trigger-testing agent",
        goal="Convert one message topic's event contract into a single JSON event-trigger test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = eventdriven.topic_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the eleven event-trigger-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return eventdriven.extract_json(str(out)) or {}

    summary = eventdriven.run_eventdriven_test(AGENT, generate)
    print(f"[{AGENT}] event_processing={summary['event_processing_success_rate_pct']}% "
          f"dlq_delivery={summary['dead_letter_queue_delivery_rate_pct']}% "
          f"scenarios={summary['scenarios_service_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
