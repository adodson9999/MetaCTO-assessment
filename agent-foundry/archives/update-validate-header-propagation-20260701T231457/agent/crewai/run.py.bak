#!/usr/bin/env python3
"""CrewAI header-propagation-testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-endpoint
Task. CrewAI routes the model through LiteLLM, so native Claude works via an
"anthropic/<model>" string. Deterministic execution (the harness sends requests,
greps the captured API server log, evaluates), recording, and emit are the shared
harness's job (agents/common/header.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import header  # noqa: E402
from header_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API header-propagation-testing agent",
        goal="Convert one endpoint's correlation-header contract into a single JSON header-propagation test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(endpoint: dict) -> dict:
        brief = header.endpoint_brief(endpoint)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the nine header-propagation-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return header.extract_json(str(out)) or {}

    summary = header.run_header_test(AGENT, generate)
    print(f"[{AGENT}] header_propagation_rate={summary['header_propagation_rate_pct']}% "
          f"endpoints={len(summary['endpoints'])} scenarios={summary['scenarios_total']}")


if __name__ == "__main__":
    main()
