#!/usr/bin/env python3
"""CrewAI pagination-testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-
collection Task. CrewAI routes the model through LiteLLM, so the local Ollama
backend works via an "ollama/<model>" string. Deterministic execution (read-only
GETs), recording, and emit are the shared harness's job (agents/common/pagination.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import pagination  # noqa: E402
from pagination_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API pagination-testing agent",
        goal="Convert one collection's pagination contract into a single JSON pagination test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = pagination.collection_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the eight pagination-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return pagination.extract_json(str(out)) or {}

    summary = pagination.run_pagination_test(AGENT, generate)
    print(f"[{AGENT}] correctness_rate={summary['pagination_correctness_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
