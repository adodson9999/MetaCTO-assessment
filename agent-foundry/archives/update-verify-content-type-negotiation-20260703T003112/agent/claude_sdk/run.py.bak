#!/usr/bin/env python3
"""Claude Agent SDK content-type-negotiation testing agent.

Standalone program mirroring the other three. Native Claude is used when the
backend is set to claude-haiku; under the air-gapped Ollama backend the SDK's cloud
path is unavailable, so it falls back to the OpenAI-compatible local endpoint.
Either way it elicits the negotiation test plan; the shared harness executes it with
real GET/write probes and records/emits.
"""
import json
import os
import sys
import asyncio
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cn  # noqa: E402
from cn_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "claude_sdk"
APPROVED_PROMPT = active_prompt()
SPEC = backend_config.resolve(WS)


async def _native(brief: str) -> str:
    """Drive the Claude Agent SDK and collect only the assistant TextBlock text.

    query() streams typed messages (HookEvent/System/Assistant/Result); an
    AssistantMessage.content is a list of blocks (ThinkingBlock has .thinking,
    TextBlock has .text). We keep only TextBlock text so extract_json sees the
    clean JSON object, not a repr of the block list.
    """
    from claude_agent_sdk import query, ClaudeAgentOptions
    opts = ClaudeAgentOptions(system_prompt=APPROVED_PROMPT, model=SPEC["native"]["model"])
    texts = []
    async for msg in query(prompt=user_message(brief), options=opts):
        content = getattr(msg, "content", None)
        if isinstance(content, list):
            for block in content:
                t = getattr(block, "text", None)
                if isinstance(t, str) and t:
                    texts.append(t)
        elif isinstance(content, str) and content:
            texts.append(content)
    return "".join(texts)


def _anthropic_sdk(brief: str) -> str:
    """Direct Anthropic Messages API (the Claude SDK proper). Used when the Claude
    Agent SDK's CLI-spawn path is unavailable (e.g. nested subprocess) — still the
    Anthropic/Claude family, never the dead local proxy. Uses ANTHROPIC_API_KEY."""
    import anthropic
    client = anthropic.Anthropic()
    msg = client.messages.create(
        model=SPEC["native"]["model"], max_tokens=1024, temperature=0,
        system=APPROVED_PROMPT,
        messages=[{"role": "user", "content": user_message(brief)}])
    return "".join(b.text for b in msg.content if getattr(b, "type", None) == "text")


def _openai_compat(brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": APPROVED_PROMPT},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    return data["choices"][0]["message"]["content"]


def _elicit(brief: str) -> str:
    if SPEC["native"]["kind"] == "anthropic":
        try:
            out = asyncio.run(_native(brief))
            if out and out.strip():
                return out
        except Exception:  # noqa  -- agent-SDK CLI spawn unavailable in this context
            pass
        return _anthropic_sdk(brief)   # robust Anthropic fallback (not the proxy)
    return _openai_compat(brief)       # ollama/local path


def main():
    def generate(cfg: dict) -> dict:
        brief = cn.endpoint_brief(cfg)
        return cn.extract_json(_elicit(brief)) or {}

    summary = cn.run_cn_test(AGENT, generate)
    print(f"[{AGENT}] negotiation_accuracy={summary['content_type_negotiation_accuracy_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
