#!/usr/bin/env python3
"""CrewAI authorization-rules testing agent.

One CrewAI Agent (role/goal/backstory carry the system prompt) handles a per-
surface Task. CrewAI routes the model through LiteLLM, so the local Ollama
backend works via an "ollama/<model>" string. Deterministic execution,
recording, and emit are the shared harness's job (agents/common/authz_contract.py).
"""
import os
import re
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import authz_contract  # noqa: E402
from authz_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = (
    Path(__file__).resolve().parents[1]
    / "subagent"
    / "api-tester-check-authorization-rules.md"
)


def _system_prompt() -> str:
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    return re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL).strip()


def _llm():
    from crewai import LLM
    if SPEC["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{SPEC['native']['model']}", temperature=0)
    return LLM(
        model=f"ollama/{SPEC['native']['model']}",
        base_url=SPEC["base_url"].replace("/v1", ""),
        temperature=0,
        response_format={"type": "json_object"},
    )


def main():
    from crewai import Agent, Task, Crew

    system = _system_prompt()
    worker = Agent(
        role="API authorization-rules testing agent",
        goal="Convert one API access surface into an eight-case authorization matrix as a single JSON object.",
        backstory=system,
        llm=_llm(),
        verbose=False,
        allow_delegation=False,
    )

    def generate(spec: dict) -> dict:
        brief = authz_contract.surface_brief(spec)
        task = Task(
            description=user_message(brief),
            agent=worker,
            expected_output='A single JSON object with the "cases" key containing eight test-case objects.',
        )
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return authz_contract.extract_json(str(out)) or {}

    summary = authz_contract.run_authz_test(AGENT, generate)
    print(
        f"[{AGENT}] access_control_accuracy={summary['access_control_accuracy_rate_pct']}% "
        f"core={summary['core_passed']}/{summary['core_sub_tests']}"
    )


if __name__ == "__main__":
    main()
