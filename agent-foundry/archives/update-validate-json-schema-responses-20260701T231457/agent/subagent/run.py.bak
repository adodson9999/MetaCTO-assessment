#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent api-tester-validate-json-schema-responses.

The agent itself is the real subagent artifact
api-tester-validate-json-schema-responses.md (YAML frontmatter + the debate-gated
body). When the backend is claude-haiku/cloud, this wrapper drives it through the
`claude` CLI as a subagent. Under the default air-gapped Ollama backend (no cloud
access), it executes the SAME subagent body through the local OpenAI-compatible
endpoint, so the agent stays measurable on the same footing as the other three.
The shared harness sends/validates/records/emits.
"""
import json
import os
import re
import shutil
import subprocess
import sys
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import schema_contract  # noqa: E402
from schema_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "api-tester-validate-json-schema-responses"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "api-tester-validate-json-schema-responses.md"


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt
    gate may override via FORGE_SKILL_DOC to evaluate a candidate skill without
    touching the artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    if SPEC["native"]["kind"] != "anthropic" or not shutil.which("claude"):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=180)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa: BLE001
        return None


def _via_local(system: str, brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": system},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]


def main():
    system = _system_prompt()

    def generate(op: dict) -> dict:
        brief = schema_contract.endpoint_brief(op)
        out = _via_claude_cli(system, brief) or _via_local(system, brief)
        return schema_contract.extract_json(out) or {}

    summary = schema_contract.run_schema_test(AGENT, generate)
    rate = summary["schema_conformance_rate_pct"]
    print(f"[{AGENT}] conformance_rate={'N/A' if rate is None else str(rate)+'%'} "
          f"validated={summary['responses_validated']} "
          f"covered={summary['endpoints_covered']}/{summary['endpoints_total']}")


if __name__ == "__main__":
    main()
