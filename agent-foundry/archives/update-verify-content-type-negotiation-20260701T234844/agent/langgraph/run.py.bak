#!/usr/bin/env python3
"""LangGraph content-type-negotiation testing agent.

A StateGraph whose single node turns one endpoint's content-negotiation contract
into the negotiation test plan via the backend (ChatAnthropic under the claude
backend, ChatOllama under the local one). Deterministic execution (real GET/write
probes), recording, and emit are handled by the shared harness (agents/common/cn.py)
so this file's only framework-specific job is LLM elicitation through LangGraph.
"""
import os
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cn  # noqa: E402
from cn_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
APPROVED_PROMPT = active_prompt()


def _caller():
    """Return call(prompt) -> str for the active backend.

    - anthropic   : ChatAnthropic (native API key)
    - openai-cli  : the OpenAI client pointed at the local `claude -p` shim
                    (claude.ai subscription; no API credits needed)
    - ollama      : ChatOllama (local)
    """
    spec = backend_config.resolve(WS)
    kind = spec["native"]["kind"]
    if kind == "anthropic":
        from langchain_anthropic import ChatAnthropic
        llm = ChatAnthropic(model=spec["native"]["model"], temperature=0, max_tokens=1024)
        return lambda p: getattr(llm.invoke(p), "content", "")
    if kind == "openai-cli":
        from openai import OpenAI
        client = OpenAI(base_url=spec["base_url"], api_key="local-shim")

        def call(p):
            r = client.chat.completions.create(
                model=spec["native"]["model"], temperature=0,
                messages=[{"role": "user", "content": p}])
            return r.choices[0].message.content or ""
        return call
    from langchain_ollama import ChatOllama
    llm = ChatOllama(model=spec["native"]["model"],
                     base_url=spec["base_url"].replace("/v1", ""),
                     temperature=0, format="json")
    return lambda p: getattr(llm.invoke(p), "content", "")


def _build_graph():
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    call = _caller()

    def generate_node(state: S) -> S:
        out = call(f"{APPROVED_PROMPT}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": out if isinstance(out, str) else str(out)}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    graph = _build_graph()

    def generate(cfg: dict) -> dict:
        brief = cn.endpoint_brief(cfg)
        result = graph.invoke({"brief": brief, "output": ""})
        return cn.extract_json(result["output"]) or {}

    summary = cn.run_cn_test(AGENT, generate)
    print(f"[{AGENT}] negotiation_accuracy={summary['content_type_negotiation_accuracy_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
