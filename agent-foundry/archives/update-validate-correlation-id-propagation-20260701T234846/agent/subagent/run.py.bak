#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent api-tester-validate-correlation-id-propagation.

The agent itself is the real subagent artifact
api-tester-validate-correlation-id-propagation.md (YAML frontmatter + the debate-gated
body). Two paths drive it:

  - the local `claude` CLI as a subagent — enabled ONLY when FORGE_SUBAGENT_USE_CLI is
    set, so a foundry run launched from inside a Claude Code session does not recursively
    spawn `claude`.
  - the documented OpenAI-compatible shim (central LiteLLM proxy for claude-haiku, or the
    local Ollama /v1 endpoint when air-gapped) — the default.

Either way it executes the SAME subagent body, so the agent stays measurable on the same
footing as the other three. The shared harness executes/records/emits.
"""
import json
import os
import re
import sys
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cid  # noqa: E402
from cid_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "api-tester-validate-correlation-id-propagation"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "api-tester-validate-correlation-id-propagation.md"


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt gate
    may override via FORGE_SKILL_DOC to evaluate a candidate skill without touching the
    artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    if (SPEC["native"]["kind"] != "anthropic" or not os.environ.get("FORGE_SUBAGENT_USE_CLI")
            or not shutil.which("claude")):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=180)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _via_local(system: str, brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": system},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]


def main():
    system = _system_prompt()

    def generate(brief: str) -> dict:
        out = _via_claude_cli(system, brief) or _via_local(system, brief)
        return cid.extract_json(out) or {}

    summary = cid.run_cid_test(AGENT, generate)
    print(f"[{AGENT}] propagation_rate={summary['correlation_id_propagation_rate_pct']}% "
          f"propagated={summary['scenarios_propagated']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
