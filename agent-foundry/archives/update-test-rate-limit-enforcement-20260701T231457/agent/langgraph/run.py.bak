#!/usr/bin/env python3
"""LangGraph rate-limit-testing agent.

A StateGraph whose single node turns one endpoint's rate-limit contract into the
rate-limit test plan via the central backend (ChatAnthropic under claude-haiku,
ChatOllama under the air-gapped default). Deterministic execution (read-only GETs
at real timing), recording, and emit are handled by the shared harness
(agents/common/ratelimit.py) so this file's only framework-specific job is LLM
elicitation through LangGraph.
"""
import os
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import ratelimit  # noqa: E402
from ratelimit_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
APPROVED_PROMPT = active_prompt()


def _model():
    spec = backend_config.resolve(WS)
    if spec["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=spec["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(model=spec["native"]["model"],
                      base_url=spec["base_url"].replace("/v1", ""),
                      temperature=0, format="json")


def _build_graph():
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{APPROVED_PROMPT}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    graph = _build_graph()

    def generate(cfg: dict) -> dict:
        brief = ratelimit.endpoint_brief(cfg)
        result = graph.invoke({"brief": brief, "output": ""})
        return ratelimit.extract_json(result["output"]) or {}

    summary = ratelimit.run_ratelimit_test(AGENT, generate)
    print(f"[{AGENT}] correctness_rate={summary['rate_limit_contract_correctness_rate_pct']}% "
          f"enforced={summary['rate_limit_enforced']} "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
