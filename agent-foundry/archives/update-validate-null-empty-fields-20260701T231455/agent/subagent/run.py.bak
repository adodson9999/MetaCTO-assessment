#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent api-tester-validate-null-empty-fields.

The agent itself is the real subagent artifact api-tester-validate-null-empty-fields.md
(YAML frontmatter + the debate-gated body). Under the claude-haiku backend this wrapper
drives that body through the `claude` CLI as a subagent. Under the air-gapped Ollama
backend (no cloud), it executes the SAME body through the local OpenAI-compatible
endpoint so the agent stays measurable on the same footing as the other three. The
shared harness sends/records/emits.
"""
import json
import os
import re
import sys
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import null_contract  # noqa: E402
from null_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "api-tester-validate-null-empty-fields"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "api-tester-validate-null-empty-fields.md"
MAX_TOKENS = int(os.environ.get("FORGE_MAX_TOKENS", "8192"))


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt gate
    may override via FORGE_SKILL_DOC to evaluate a candidate without touching the artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    if SPEC["native"]["kind"] != "anthropic" or not shutil.which("claude"):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=240)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _via_local(system: str, brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0, "max_tokens": MAX_TOKENS,
        "messages": [{"role": "system", "content": system},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]


def main():
    system = _system_prompt()

    def generate(ep: dict) -> dict:
        brief = null_contract.endpoint_brief(ep)
        out = _via_claude_cli(system, brief) or _via_local(system, brief)
        return null_contract.extract_json(out) or {}

    summary = null_contract.run_null_test(AGENT, generate)
    print(f"[{AGENT}] accuracy={summary['null_empty_validation_accuracy_pct']}% "
          f"cases={summary['total_cases']}")


if __name__ == "__main__":
    main()
