#!/usr/bin/env python3
"""CrewAI timeout-handling testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-service
Task. CrewAI routes the model through LiteLLM, so the local Ollama backend works via
an "ollama/<model>" string (and claude-haiku via "anthropic/<model>" when the backend
is switched). Deterministic execution (raw-socket probes), recording, and emit are the
shared harness's job (agents/common/timeout.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import timeout as harness  # noqa: E402
from timeout_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API timeout-handling testing agent",
        goal="Convert one service's documented upstream-timeout contract into a single JSON timeout test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = harness.service_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the seven timeout-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return harness.extract_json(str(out)) or {}

    summary = harness.run_timeout_test(AGENT, generate)
    print(f"[{AGENT}] enforcement_rate={summary['timeout_enforcement_rate_pct']}% "
          f"endpoints={summary['endpoints_enforced']}/{summary['endpoints_total']}")


if __name__ == "__main__":
    main()
