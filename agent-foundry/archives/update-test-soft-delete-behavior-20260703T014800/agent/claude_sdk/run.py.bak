#!/usr/bin/env python3
"""Claude Agent SDK soft-delete-behavior agent.

Standalone program mirroring the other three. Native Claude is used when the backend is
set to claude-haiku (this build's backend); under an air-gapped Ollama backend the SDK's
cloud path is unavailable, so it falls back to the OpenAI-compatible local endpoint.
Either way it elicits the soft-delete test plan; the shared harness executes it (the
case_count create->delete->verify lifecycles + direct DB query) and records/emits.
"""
import json
import os
import sys
import asyncio
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import softdelete  # noqa: E402
from softdelete_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "claude_sdk"
APPROVED_PROMPT = active_prompt()
SPEC = backend_config.resolve(WS)


async def _native(brief: str) -> str:
    from claude_agent_sdk import query, ClaudeAgentOptions
    opts = ClaudeAgentOptions(system_prompt=APPROVED_PROMPT, model=SPEC["native"]["model"])
    chunks = []
    async for msg in query(prompt=user_message(brief), options=opts):
        content = getattr(msg, "content", None)
        if isinstance(content, list):
            for block in content:
                chunks.append(getattr(block, "text", str(block)))
        elif content is not None:
            chunks.append(str(content))
    return "".join(chunks)


def _openai_compat(brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": APPROVED_PROMPT},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    return data["choices"][0]["message"]["content"]


def _elicit(brief: str) -> str:
    if SPEC["native"]["kind"] == "anthropic":
        try:
            return asyncio.run(_native(brief))
        except Exception:  # noqa  -- cloud path unavailable air-gapped
            pass
    return _openai_compat(brief)


def main():
    def generate(cfg: dict) -> dict:
        b = softdelete.brief(cfg)
        return softdelete.extract_json(_elicit(b)) or {}

    summary = softdelete.run_softdelete_test(AGENT, generate)
    print(f"[{AGENT}] correctness_rate={summary['soft_delete_correctness_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']} "
          f"cases_ok={summary['correct_cases']}/{summary['total_cases']}")


if __name__ == "__main__":
    main()
