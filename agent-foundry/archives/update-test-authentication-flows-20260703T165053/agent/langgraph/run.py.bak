#!/usr/bin/env python3
"""LangGraph authentication-flows testing agent.

A StateGraph whose single node converts one API's authentication scheme into a
flow-test plan via the local backend. Deterministic execution, recording, and
emit are handled by the shared harness (agents/common/auth_harness.py) so this
file's only framework-specific job is LLM elicitation through LangGraph.
"""
import os
import re
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import auth_harness  # noqa: E402
from auth_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = (
    Path(__file__).resolve().parents[1]
    / "subagent"
    / "api-tester-test-authentication-flows.md"
)


def _system_prompt() -> str:
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    return re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL).strip()


def _model():
    if SPEC["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=SPEC["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(
        model=SPEC["native"]["model"],
        base_url=SPEC["base_url"].replace("/v1", ""),
        temperature=0,
        format="json",
    )


def _build_graph(system: str, brief: str):
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{system}\n\n{user_message(brief)}")
        return {"output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    system = _system_prompt()
    brief = auth_harness.scheme_brief()
    graph = _build_graph(system, brief)

    def generate() -> dict:
        result = graph.invoke({"output": ""})
        return auth_harness.extract_json(result["output"]) or {}

    summary = auth_harness.run_auth_test(AGENT, generate)
    print(
        f"[{AGENT}] pass_rate={summary['auth_flow_pass_rate_pct']}% "
        f"FAR={summary['false_acceptance_rate_pct']}% "
        f"FRR={summary['false_rejection_rate_pct']}% "
        f"executed={summary['executed_cases']}"
    )


if __name__ == "__main__":
    main()
