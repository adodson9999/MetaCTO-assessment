#!/usr/bin/env python3
"""CrewAI correlation-ID-propagation agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a single Task.
CrewAI routes the model through LiteLLM, so claude-haiku works via an
"anthropic/<model>" string and the local Ollama backend via "ollama/<model>".
Deterministic execution (auth login, the two requests, log grepping), recording, and
emit are the shared harness's job (agents/common/cid.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cid  # noqa: E402
from cid_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API correlation-ID-propagation testing agent",
        goal="Convert the fixed correlation-ID propagation contract into a single JSON propagation test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(brief: str) -> dict:
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the eight propagation-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return cid.extract_json(str(out)) or {}

    summary = cid.run_cid_test(AGENT, generate)
    print(f"[{AGENT}] propagation_rate={summary['correlation_id_propagation_rate_pct']}% "
          f"propagated={summary['scenarios_propagated']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
