#!/usr/bin/env python3
"""CrewAI null-and-empty-fields testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-endpoint
Task. CrewAI routes the model through LiteLLM, so the claude-haiku backend works via
an "anthropic/<model>" string and the air-gapped Ollama backend via "ollama/<model>".
Deterministic execution (real HTTP sends), recording, and emit are the shared
harness's job (agents/common/null_contract.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import null_contract  # noqa: E402
from null_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()
MAX_TOKENS = int(os.environ.get("FORGE_MAX_TOKENS", "8192"))


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0, max_tokens=MAX_TOKENS)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API null-and-empty-fields testing agent",
        goal="Convert one endpoint's request-body schema into a single JSON null/empty test matrix.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(ep: dict) -> dict:
        brief = null_contract.endpoint_brief(ep)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the six null/empty-matrix keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return null_contract.extract_json(str(out)) or {}

    summary = null_contract.run_null_test(AGENT, generate)
    print(f"[{AGENT}] accuracy={summary['null_empty_validation_accuracy_pct']}% "
          f"cases={summary['total_cases']}")


if __name__ == "__main__":
    main()
