#!/usr/bin/env python3
"""CrewAI Run-Regression-Suite agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-build-pair
Task. CrewAI routes the model through LiteLLM, so claude-haiku works via an
"anthropic/<model>" string and the local Ollama backend via "ollama/<model>".
Deterministic gold comparison, scoring, and emit are the shared harness's job
(agents/common/regression.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import regression  # noqa: E402
from regression_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API regression-suite reporting agent",
        goal="Compare one build pair's two test-result artifacts and emit a single seven-field JSON regression report.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = regression.pair_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the seven regression-report keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return regression.extract_json(str(out)) or {}

    summary = regression.run_regression_test(AGENT, generate)
    print(f"[{AGENT}] fidelity={summary['regression_report_fidelity_pct']}% "
          f"fields={summary['fields_correct']}/{summary['fields_total']} "
          f"block={summary['builds_that_must_block_deployment']}")


if __name__ == "__main__":
    main()
