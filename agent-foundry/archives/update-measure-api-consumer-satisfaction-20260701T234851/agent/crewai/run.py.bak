#!/usr/bin/env python3
"""CrewAI Measure-API-Consumer-Satisfaction agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a single Task that
renders the documented NPS-survey-measurement contract as the JSON measurement plan.
CrewAI routes the model through LiteLLM, so claude-haiku works via an "anthropic/<model>"
string and the local Ollama backend via "ollama/<model>". Deterministic execution,
recording, and emit are the shared harness's job (agents/common/nps.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import nps  # noqa: E402
from nps_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API consumer-satisfaction measurement-planning agent",
        goal="Convert the documented NPS-survey-measurement contract into a single JSON measurement plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(brief: str) -> dict:
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the eight measurement-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return nps.extract_json(str(out)) or {}

    summary = nps.run_nps_test(AGENT, generate)
    print(f"[{AGENT}] nps={summary['nps_score']} "
          f"plan_accuracy={summary['plan_accuracy_pct']}% "
          f"scenarios={summary['scenarios_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
