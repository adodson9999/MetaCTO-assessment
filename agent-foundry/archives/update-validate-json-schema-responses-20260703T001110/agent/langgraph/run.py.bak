#!/usr/bin/env python3
"""LangGraph response-schema-validation agent.

A StateGraph whose single node turns one endpoint brief into the valid request
descriptor + documented-schema map via the local backend (ChatOllama). The
deterministic sending, ajv validation, recording, and emit are handled by the
shared harness (agents/common/schema_contract.py), so this file's only
framework-specific job is LLM elicitation through LangGraph.
"""
import os
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import schema_contract  # noqa: E402
from schema_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
APPROVED_PROMPT = active_prompt()


def _model():
    spec = backend_config.resolve(WS)
    if spec["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=spec["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(model=spec["native"]["model"],
                      base_url=spec["base_url"].replace("/v1", ""),
                      temperature=0, format="json")


def _build_graph():
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{APPROVED_PROMPT}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    graph = _build_graph()

    def generate(op: dict) -> dict:
        brief = schema_contract.endpoint_brief(op)
        result = graph.invoke({"brief": brief, "output": ""})
        return schema_contract.extract_json(result["output"]) or {}

    summary = schema_contract.run_schema_test(AGENT, generate)
    rate = summary["schema_conformance_rate_pct"]
    print(f"[{AGENT}] conformance_rate={'N/A' if rate is None else str(rate)+'%'} "
          f"validated={summary['responses_validated']} "
          f"covered={summary['endpoints_covered']}/{summary['endpoints_total']}")


if __name__ == "__main__":
    main()
