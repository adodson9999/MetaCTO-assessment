{
  "agent": "api-tester-validate-api-versioning-behavior",
  "lane": "api-version-contract",
  "cases": [
    {
      "role": "path_current",
      "channel": "path",
      "method": "GET",
      "version_status": "current",
      "schema": "current_schema",
      "recipe": {
        "kind": "path_version",
        "select": "current"
      },
      "assertions": [
        "no_deprecation_header"
      ],
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "path_deprecated",
      "channel": "path",
      "method": "GET",
      "version_status": "deprecated",
      "schema": "deprecated_schema",
      "recipe": {
        "kind": "path_version",
        "select": "deprecated"
      },
      "assertions": [
        "deprecation_header_future_dated",
        "sunset_header_present",
        "successor_link_header_present"
      ],
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "path_unsupported_numeric",
