      "kind": "create",
      "endpoint_role": "create_endpoint",
      "method": "POST",
      "asserts": {
        "field_echo": "created_fields_equal_submitted_create_fields",
        "returns_new_id": true
      },
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "read",
      "kind": "read",
      "endpoint_role": "item_endpoint",
      "method": "GET",
      "asserts": {
        "field_echo": "read_fields_equal_created_state"
      },
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "update",
      "kind": "update",
      "endpoint_role": "item_endpoint",
      "method": "PUT",
      "asserts": {
        "field_echo": "updated_fields_equal_submitted_update_fields"
      },
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "delete",
      "kind": "delete",
      "endpoint_role": "item_endpoint",
      "method": "DELETE",
      "asserts": {
        "soft_delete_markers": "documented_soft_delete_markers_present"
      },
      "expected_class": "2xx",
      "also_accept": []
    },
    {
      "role": "write_persistence",
      "kind": "write_persistence_proof",
      "endpoint_role": "item_endpoint",
