      "method": "GET",
      "asserts": {
        "not_found": "known_nonexistent_item_id"
      },
      "expected_class": "404",
      "also_accept": []
    },
    {
      "role": "update_not_found",
      "kind": "update",
      "endpoint_role": "item_endpoint_nonexistent_id",
      "method": "PUT",
      "asserts": {
        "not_found": "known_nonexistent_item_id"
      },
      "expected_class": "404",
      "also_accept": []
    },
    {
      "role": "delete_not_found",
      "kind": "delete",
      "endpoint_role": "item_endpoint_nonexistent_id",
      "method": "DELETE",
      "asserts": {
        "not_found": "known_nonexistent_item_id"
      },
      "expected_class": "404",
      "also_accept": []
    }
