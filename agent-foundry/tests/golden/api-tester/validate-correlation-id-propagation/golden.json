{
  "agent": "api-tester-validate-correlation-id-propagation",
  "lane": "correlation-id-semantics",
  "plan": {
    "target_endpoint": "target_endpoint_role",
    "correlation_id_header": "correlation_id_header_role",
    "known_correlation_id": "known_correlation_id_role",
    "uuid_v4_regex": "uuid_v4_regex_role",
    "downstream_services": "downstream_service_roles"
  },
  "cases": [
    {
      "role": "with_header_echo",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_known_correlation_id",
        "header": "correlation_id_header_role",
        "value": "known_correlation_id_role"
      },
      "expected_class": "2xx",
      "also_accept": [],
      "asserts": {
        "assert_response_echoes_id_byte_for_byte": true
      },
      "steps": [
        {"step": "send_with_known_correlation_id", "detail": "issue one request to target_endpoint_role carrying the known correlation id in correlation_id_header_role"},
        {"step": "capture_response_headers", "detail": "capture the response headers returned by the target endpoint"},
        {"step": "assert_response_echoes_id_byte_for_byte", "detail": "the response echoes the known correlation id byte-for-byte with no change to characters, case, whitespace, or length"}
      ]
    },
    {
      "role": "log_present_unmodified",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_known_correlation_id",
        "header": "correlation_id_header_role",
        "value": "known_correlation_id_role"
      },
      "expected_class": "2xx",
      "also_accept": [],
      "asserts": {
        "assert_id_in_api_log_unmodified": true,
        "assert_downstream_log_count_ge_service_count": true,
        "assert_id_in_every_downstream_log_unmodified": true
      },
      "steps": [
        {"step": "send_with_known_correlation_id", "detail": "issue one request to target_endpoint_role carrying the known correlation id"},
        {"step": "grep_api_log_for_id", "detail": "grep the captured API log for the known correlation id"},
        {"step": "assert_id_in_api_log_unmodified", "detail": "the known correlation id appears unmodified in the API log"},
        {"step": "grep_each_downstream_log_for_id", "detail": "grep every downstream service log in downstream_service_roles for the known correlation id"},
        {"step": "assert_downstream_log_count_ge_service_count", "detail": "the id is found in a number of downstream logs at least equal to the provided downstream service count"},
        {"step": "assert_id_in_every_downstream_log_unmodified", "detail": "the known correlation id appears unmodified in each downstream service log"}
      ]
    },
    {
      "role": "no_header_uuidv4_autogen",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_without_correlation_id_header",
        "omit_header": "correlation_id_header_role"
      },
      "expected_class": "2xx",
      "also_accept": [],
      "asserts": {
        "assert_autogenerated_id_matches_uuid_v4_regex": true,
        "assert_autogenerated_id_in_api_log": true,
        "assert_autogenerated_id_in_every_downstream_log": true
      },
      "steps": [
        {"step": "send_without_correlation_id_header", "detail": "issue one request to target_endpoint_role with no correlation_id_header_role present"},
        {"step": "capture_generated_id", "detail": "capture the correlation id the service generated for this request"},
        {"step": "assert_autogenerated_id_matches_uuid_v4_regex", "detail": "the generated id matches uuid_v4_regex_role exactly"},
        {"step": "grep_api_log_for_generated_id", "detail": "grep the captured API log for the generated id"},
        {"step": "assert_autogenerated_id_in_api_log", "detail": "the generated id appears in the API log"},
        {"step": "grep_each_downstream_log_for_generated_id", "detail": "grep every downstream service log in downstream_service_roles for the generated id"},
        {"step": "assert_autogenerated_id_in_every_downstream_log", "detail": "the generated id appears in every downstream service log"}
      ]
    },
    {
      "role": "uniqueness_two_no_header",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_two_without_correlation_id_header",
        "omit_header": "correlation_id_header_role",
        "count": 2
      },
      "expected_class": "2xx",
      "also_accept": [],
      "asserts": {
        "assert_each_generated_id_matches_uuid_v4_regex": true,
        "assert_two_generated_ids_differ": true
      },
      "steps": [
        {"step": "send_first_without_correlation_id_header", "detail": "issue a first request to target_endpoint_role with no correlation_id_header_role present"},
        {"step": "send_second_without_correlation_id_header", "detail": "issue a second request to target_endpoint_role with no correlation_id_header_role present"},
        {"step": "capture_both_generated_ids", "detail": "capture the correlation id generated for each of the two requests"},
        {"step": "assert_each_generated_id_matches_uuid_v4_regex", "detail": "each generated id matches uuid_v4_regex_role exactly"},
        {"step": "assert_two_generated_ids_differ", "detail": "the two generated ids are different from each other"}
      ]
    },
    {
      "role": "id_in_error",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_known_correlation_id_forcing_error",
        "header": "correlation_id_header_role",
        "value": "known_correlation_id_role"
      },
      "expected_class": "4xx",
      "also_accept": [
        "5xx"
      ],
      "asserts": {
        "assert_error_response_echoes_id_byte_for_byte": true
      },
      "steps": [
        {"step": "send_with_known_correlation_id_forcing_error", "detail": "issue one request to target_endpoint_role that drives an error response while carrying the known correlation id"},
        {"step": "capture_error_response_headers", "detail": "capture the headers on the error response"},
        {"step": "assert_error_response_echoes_id_byte_for_byte", "detail": "the error response still echoes the known correlation id byte-for-byte"}
      ]
    },
    {
      "role": "malformed_id_handling",
      "endpoint_role": "target_endpoint_role",
      "method": "GET",
      "recipe": {
        "kind": "send_malformed_correlation_id",
        "header": "correlation_id_header_role",
        "malformations": [
          "over_long",
          "crlf_and_control_characters",
          "injection_metacharacters"
        ]
      },
      "expected_class": "sanitized_or_rejected",
      "also_accept": [],
      "asserts": {
        "assert_malformed_id_not_reflected_raw_in_response": true,
        "assert_malformed_id_not_reflected_raw_in_any_log": true,
        "assert_rejected_or_sanitized": true
      },
      "steps": [
        {"step": "send_over_long_correlation_id", "detail": "issue a request carrying an over-long correlation id in correlation_id_header_role"},
        {"step": "send_crlf_control_correlation_id", "detail": "issue a request carrying a correlation id with CRLF and control characters"},
        {"step": "send_injection_metacharacter_correlation_id", "detail": "issue a request carrying a correlation id with injection metacharacters"},
        {"step": "capture_responses_and_logs", "detail": "capture each response header set and grep the captured API and downstream logs"},
        {"step": "assert_malformed_id_not_reflected_raw_in_response", "detail": "no malformed correlation id is reflected raw into any response header"},
        {"step": "assert_malformed_id_not_reflected_raw_in_any_log", "detail": "no malformed correlation id is reflected raw into any API or downstream log"},
        {"step": "assert_rejected_or_sanitized", "detail": "each malformed correlation id is rejected or sanitized rather than propagated"}
      ]
    }
  ],
  "execution": {
    "mode": "deterministic_harness",
    "network_by_agent": false,
    "note": "the harness sends the requests and greps the captured API and downstream logs; the agent emits plan only"
  },
  "log": {
    "steps_logged": true,
    "note": "each case carries a maximally granular, fully-logged steps array"
  },
  "report": {
    "cases_total": 6,
    "out_of_scope": null
  },
  "out_of_scope": null,
  "baseline": {
    "metric": "correlation_id_propagation_fidelity",
    "value": 1.0
  }
}
