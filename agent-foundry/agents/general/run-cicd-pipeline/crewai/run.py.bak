#!/usr/bin/env python3
"""CrewAI CI/CD-Pipeline-Runner agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-pipeline-run
Task. CrewAI routes the model through LiteLLM, so the local Ollama backend works via an
"ollama/<model>" string (the default for this task) and claude-haiku via
"anthropic/<model>". Deterministic gold comparison, scoring, and emit are the shared
harness's job (agents/common/cicd.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cicd  # noqa: E402
from cicd_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="CI/CD pipeline-runner reporting agent",
        goal="Classify the enabled agents of one pipeline run and emit a single ten-field JSON pipeline-summary.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = cicd.run_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the ten pipeline-summary keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return cicd.extract_json(str(out)) or {}

    summary = cicd.run_cicd_test(AGENT, generate)
    print(f"[{AGENT}] fidelity={summary['pipeline_summary_fidelity_pct']}% "
          f"fields={summary['fields_correct']}/{summary['fields_total']} "
          f"block={summary['runs_that_must_block_deployment']}")


if __name__ == "__main__":
    main()
