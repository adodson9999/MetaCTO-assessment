#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent general-run-cicd-pipeline.

The agent itself is the real subagent artifact general-run-cicd-pipeline.md
(YAML frontmatter + the debate-gated body). Paths that drive it:

  - the local `claude` CLI as a subagent — enabled ONLY when FORGE_SUBAGENT_USE_CLI is
    set AND the backend is anthropic, so a foundry run launched from inside a Claude
    Code session does not recursively spawn `claude`.
  - the documented OpenAI-compatible shim — the local Ollama /v1 endpoint (this task's
    default, air-gapped) or the central LiteLLM proxy for claude-haiku.

Either way it executes the SAME subagent body, so the agent stays measurable on the
same footing as the other three. The shared harness compares to gold and emits.
"""
import json
import os
import re
import sys
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cicd  # noqa: E402
from cicd_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "general-run-cicd-pipeline"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "general-run-cicd-pipeline.md"


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt gate
    may override via FORGE_SKILL_DOC to evaluate a candidate skill without touching
    the artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    if (SPEC["native"]["kind"] != "anthropic" or not os.environ.get("FORGE_SUBAGENT_USE_CLI")
            or not shutil.which("claude")):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=240)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _via_anthropic_sdk(system: str, brief: str) -> str | None:
    """Direct Anthropic SDK call on claude-haiku, executing the SAME gated subagent
    body as the system prompt. Used when the OpenAI-compatible LiteLLM shim is not
    running, so the subagent is still measured on the same backend/model without
    spawning a recursive `claude` CLI."""
    if SPEC["native"]["kind"] != "anthropic":
        return None
    try:
        import anthropic
        client = anthropic.Anthropic()
        msg = client.messages.create(
            model=SPEC["native"]["model"], max_tokens=2048, temperature=0,
            system=system,
            messages=[{"role": "user", "content": user_message(brief)}])
        return "".join(getattr(b, "text", "") for b in msg.content)
    except Exception:  # noqa
        return None


def _via_local(system: str, brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": system},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]


def main():
    system = _system_prompt()

    def generate(cfg: dict) -> dict:
        brief = cicd.run_brief(cfg)
        # opt-in claude CLI -> direct Anthropic SDK (claude-haiku) -> OpenAI-compat shim.
        out = (_via_claude_cli(system, brief)
               or _via_anthropic_sdk(system, brief)
               or _via_local(system, brief))
        return cicd.extract_json(out) or {}

    summary = cicd.run_cicd_test(AGENT, generate)
    print(f"[{AGENT}] fidelity={summary['pipeline_summary_fidelity_pct']}% "
          f"fields={summary['fields_correct']}/{summary['fields_total']} "
          f"block={summary['runs_that_must_block_deployment']}")


if __name__ == "__main__":
    main()
