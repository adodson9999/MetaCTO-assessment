#!/usr/bin/env python3
"""LangGraph test-case-creator agent (n600).

A StateGraph whose single node turns one agent spec's How section into the array of
test-case objects via the local backend (ChatOllama). Deterministic manifest read,
gold computation, registry/summary/gaps write, and the count assertion are handled by
the shared harness (agents/common/testcase.py) so this file's only framework-specific
job is LLM elicitation through LangGraph.
"""
import os
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import testcase  # noqa: E402
from testcase_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
APPROVED_PROMPT = active_prompt()


def _model():
    spec = backend_config.resolve(WS)
    if spec["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=spec["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(model=spec["native"]["model"],
                      base_url=spec["base_url"].replace("/v1", ""),
                      temperature=0)


def _build_graph():
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{APPROVED_PROMPT}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    graph = _build_graph()

    def generate(cfg: dict) -> list:
        brief = testcase.agent_brief(cfg)
        result = graph.invoke({"brief": brief, "output": ""})
        return testcase.extract_json_array(result["output"]) or []

    summary = testcase.run_testcase_test(AGENT, generate)
    print(f"[{AGENT}] coverage_rate={summary['test_case_coverage_rate_pct']}% "
          f"field_accuracy={summary['test_case_field_accuracy_pct']}% "
          f"cases={summary['present_tc']}/{summary['gold_tc']}")


if __name__ == "__main__":
    main()
