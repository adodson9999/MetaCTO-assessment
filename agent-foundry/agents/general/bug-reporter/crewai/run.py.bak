#!/usr/bin/env python3
"""CrewAI bug-reporter agent ("n602").

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-failure Task.
CrewAI routes the model through LiteLLM, so the Claude backend works via an
"anthropic/<model>" string (and Ollama via "ollama/<model>"). Deterministic execution
(materialise the file artifacts, assemble the bug reports + index, score), recording, and
emit are the shared harness's job (agents/common/bugreport.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import bugreport  # noqa: E402
from bugreport_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    kind = spec["native"]["kind"]
    if kind == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    if kind == "openai-cli":
        os.environ.setdefault("OPENAI_API_KEY", "local-shim")
        return LLM(model=f"openai/{spec['native']['model']}",
                   base_url=spec["base_url"], api_key="local-shim", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API bug-reporter analysis agent (n602)",
        goal="Convert one failed agent's captured artifacts into a single five-key JSON bug-report decision.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(brief: str) -> dict:
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the five bug-report-decision keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return bugreport.extract_json(str(out)) or {}

    s = bugreport.run_bugreport_test(AGENT, generate)
    m = s["metrics"]
    print(f"[{AGENT}] fidelity={s['bug_report_fidelity_pct']}% "
          f"bugs={s['bug_count']} completeness={m['bug_report_completeness_rate_pct']}% "
          f"exit1={m['would_exit_code_1']}")


if __name__ == "__main__":
    main()
