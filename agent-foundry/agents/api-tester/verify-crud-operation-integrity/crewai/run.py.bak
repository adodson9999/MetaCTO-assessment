#!/usr/bin/env python3
"""CrewAI CRUD-integrity-testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-resource
Task. CrewAI routes the model through LiteLLM, so claude-haiku works via an
"anthropic/<model>" string and the local Ollama backend via "ollama/<model>".
Deterministic execution/DB-reads/scoring/emit is the shared harness's job
(agents/common/crud_contract.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import crud_contract  # noqa: E402
from crud_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API CRUD-integrity testing agent",
        goal="Convert one resource's CRUD contract into an ordered 8-step test plan as JSON.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(resource: dict) -> dict:
        brief = crud_contract.resource_brief(resource)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output='A single JSON object with two keys "table" and '
                                    '"steps" (six request descriptors in fixed order).')
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return crud_contract.extract_json(str(out)) or {}

    summary = crud_contract.run_crud_test(AGENT, generate)
    print(f"[{AGENT}] crud_integrity_rate={summary['crud_integrity_rate_pct']}% "
          f"passing={summary['resource_types_passing']}/{summary['resource_types']} "
          f"covered_steps={summary['covered_step_cells']}")


if __name__ == "__main__":
    main()
