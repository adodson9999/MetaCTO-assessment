#!/usr/bin/env python3
"""Claude Agent SDK header-propagation-testing agent.

Standalone program mirroring the other three. Native Claude is used when the backend
is claude-haiku; under an air-gapped Ollama backend the SDK's cloud path is
unavailable, so it falls back to the OpenAI-compatible local endpoint. Either way it
elicits the propagation test plan; the shared harness sends the requests, greps the
captured API server log, evaluates, and records/emits.
"""
import json
import os
import sys
import asyncio
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import header  # noqa: E402
from header_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "claude_sdk"
APPROVED_PROMPT = active_prompt()
SPEC = backend_config.resolve(WS)


def _msg_text(msg) -> str:
    """Pull plain text out of a claude_agent_sdk message. AssistantMessage.content is
    a list of content blocks (TextBlock.text); other message types (system/result)
    carry no plan text and are skipped."""
    content = getattr(msg, "content", None)
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for block in content:
            t = getattr(block, "text", None)
            if isinstance(t, str):
                parts.append(t)
        return "".join(parts)
    return ""


async def _native(brief: str) -> str:
    from claude_agent_sdk import query, ClaudeAgentOptions
    opts = ClaudeAgentOptions(system_prompt=APPROVED_PROMPT, model=SPEC["native"]["model"])
    chunks = []
    async for msg in query(prompt=user_message(brief), options=opts):
        text = _msg_text(msg)
        if text:
            chunks.append(text)
    return "".join(chunks)


def _openai_compat(brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": APPROVED_PROMPT},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    return data["choices"][0]["message"]["content"]


def _elicit(brief: str) -> str:
    if SPEC["native"]["kind"] == "anthropic":
        try:
            return asyncio.run(_native(brief))
        except Exception:  # noqa  -- cloud path unavailable air-gapped
            pass
    return _openai_compat(brief)


def main():
    def generate(endpoint: dict) -> dict:
        brief = header.endpoint_brief(endpoint)
        return header.extract_json(_elicit(brief)) or {}

    summary = header.run_header_test(AGENT, generate)
    print(f"[{AGENT}] header_propagation_rate={summary['header_propagation_rate_pct']}% "
          f"endpoints={len(summary['endpoints'])} scenarios={summary['scenarios_total']}")


if __name__ == "__main__":
    main()
