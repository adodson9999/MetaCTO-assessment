#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent api-tester-validate-api-versioning-behavior.

The agent itself is the real subagent artifact
api-tester-validate-api-versioning-behavior.md (YAML frontmatter + the debate-gated
body). Two paths drive it:

  - the local `claude` CLI as a subagent — enabled ONLY when FORGE_SUBAGENT_USE_CLI
    is set, so a foundry run launched from inside a Claude Code session does not
    recursively spawn `claude`.
  - the documented OpenAI-compatible shim (in-process LiteLLM for claude-haiku, or the
    local Ollama /v1 endpoint when air-gapped) — the default.

Either way it executes the SAME subagent body, so the agent stays measurable on the
same footing as the other three. The shared harness executes/records/emits.
"""
import json
import os
import re
import sys
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import versioning  # noqa: E402
from versioning_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "api-tester-validate-api-versioning-behavior"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "api-tester-validate-api-versioning-behavior.md"
TOTALS = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}


def _add_usage(usage) -> None:
    """Accumulate token usage from a litellm/OpenAI response 'usage' (best-effort).
    The CLI path exposes no token counts, so usage stays zero there."""
    if usage is None:
        return
    g = (lambda k: usage.get(k) if isinstance(usage, dict) else getattr(usage, k, None))
    TOTALS["prompt_tokens"] += int(g("prompt_tokens") or 0)
    TOTALS["completion_tokens"] += int(g("completion_tokens") or 0)
    TOTALS["total_tokens"] += int(g("total_tokens") or 0)


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt
    gate may override via FORGE_SKILL_DOC to evaluate a candidate skill without
    touching the artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    if (SPEC["native"]["kind"] != "anthropic" or not os.environ.get("FORGE_SUBAGENT_USE_CLI")
            or not shutil.which("claude")):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=180)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _via_local(system: str, brief: str) -> str:
    messages = [{"role": "system", "content": system},
                {"role": "user", "content": user_message(brief)}]
    if SPEC["native"]["kind"] == "anthropic":
        # In-process LiteLLM shim — no proxy server needed; uses ANTHROPIC_API_KEY.
        import litellm
        r = litellm.completion(model=f"anthropic/{SPEC['native']['model']}",
                               temperature=0, messages=messages)
        _add_usage(r.get("usage") if isinstance(r, dict) else getattr(r, "usage", None))
        return r["choices"][0]["message"]["content"]
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": messages, "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    _add_usage(data.get("usage"))
    return data["choices"][0]["message"]["content"]


def main():
    system = _system_prompt()

    def generate(cfg: dict) -> dict:
        brief = versioning.endpoint_brief(cfg)
        out = _via_claude_cli(system, brief) or _via_local(system, brief)
        return versioning.extract_json(out) or {}

    summary = versioning.run_versioning_test(AGENT, generate, usage=lambda: TOTALS)
    print(f"[{AGENT}] accuracy={summary['version_routing_accuracy_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']} "
          f"tokens={summary['tokens']['total_tokens']}")


if __name__ == "__main__":
    main()
