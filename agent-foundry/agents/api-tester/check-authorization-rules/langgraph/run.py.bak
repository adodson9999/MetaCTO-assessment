#!/usr/bin/env python3
"""LangGraph authorization-rules testing agent.

A StateGraph whose single node converts one API's access surface into the
eight-case authorization matrix via the local backend. Deterministic execution,
recording, and emit are handled by the shared harness (agents/common/authz_contract.py)
so this file's only framework-specific job is LLM elicitation through LangGraph.
"""
import os
import re
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import authz_contract  # noqa: E402
from authz_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = (
    Path(__file__).resolve().parents[1]
    / "subagent"
    / "api-tester-check-authorization-rules.md"
)


def _system_prompt() -> str:
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    return re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL).strip()


def _model():
    if SPEC["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=SPEC["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(
        model=SPEC["native"]["model"],
        base_url=SPEC["base_url"].replace("/v1", ""),
        temperature=0,
        format="json",
    )


def _build_graph(system: str):
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{system}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    system = _system_prompt()
    graph = _build_graph(system)

    def generate(spec: dict) -> dict:
        brief = authz_contract.surface_brief(spec)
        result = graph.invoke({"brief": brief, "output": ""})
        return authz_contract.extract_json(result["output"]) or {}

    summary = authz_contract.run_authz_test(AGENT, generate)
    print(
        f"[{AGENT}] access_control_accuracy={summary['access_control_accuracy_rate_pct']}% "
        f"core={summary['core_passed']}/{summary['core_sub_tests']}"
    )


if __name__ == "__main__":
    main()
