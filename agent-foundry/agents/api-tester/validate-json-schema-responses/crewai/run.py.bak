#!/usr/bin/env python3
"""CrewAI response-schema-validation agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-
endpoint Task. CrewAI routes the model through LiteLLM, so the local Ollama
backend works via an "ollama/<model>" string. Deterministic sending/validation/
recording/emit is the shared harness's job (agents/common/schema_contract.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import schema_contract  # noqa: E402
from schema_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API response-schema validation agent",
        goal="Convert one endpoint into one valid request descriptor plus its documented response-schema map.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(op: dict) -> dict:
        brief = schema_contract.endpoint_brief(op)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output='A single JSON object with keys "request" and '
                                    '"documented_response_schemas".')
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return schema_contract.extract_json(str(out)) or {}

    summary = schema_contract.run_schema_test(AGENT, generate)
    rate = summary["schema_conformance_rate_pct"]
    print(f"[{AGENT}] conformance_rate={'N/A' if rate is None else str(rate)+'%'} "
          f"validated={summary['responses_validated']} "
          f"covered={summary['endpoints_covered']}/{summary['endpoints_total']}")


if __name__ == "__main__":
    main()
