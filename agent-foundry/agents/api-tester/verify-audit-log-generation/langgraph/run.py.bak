#!/usr/bin/env python3
"""LangGraph audit-log-verification agent.

A StateGraph whose single node turns one collection's audit-logging contract into the
audit-verification test plan via the configured backend. Deterministic execution (auth,
the create/update/delete operations, log capture + query), recording, and emit are
handled by the shared harness (agents/common/auditlog.py) so this file's only
framework-specific job is LLM elicitation through LangGraph.
"""
import os
import sys
from pathlib import Path
from typing import TypedDict

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import auditlog  # noqa: E402
from auditlog_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "langgraph"
APPROVED_PROMPT = active_prompt()


def _model():
    spec = backend_config.resolve(WS)
    if spec["native"]["kind"] == "anthropic":
        from langchain_anthropic import ChatAnthropic
        return ChatAnthropic(model=spec["native"]["model"], temperature=0)
    from langchain_ollama import ChatOllama
    return ChatOllama(model=spec["native"]["model"],
                      base_url=spec["base_url"].replace("/v1", ""),
                      temperature=0, format="json")


def _build_graph():
    from langgraph.graph import StateGraph, END

    class S(TypedDict):
        brief: str
        output: str

    llm = _model()

    def generate_node(state: S) -> S:
        msg = llm.invoke(f"{APPROVED_PROMPT}\n\n{user_message(state['brief'])}")
        return {"brief": state["brief"], "output": getattr(msg, "content", str(msg))}

    g = StateGraph(S)
    g.add_node("generate", generate_node)
    g.set_entry_point("generate")
    g.add_edge("generate", END)
    return g.compile()


def main():
    graph = _build_graph()

    def generate(cfg: dict) -> dict:
        brief = auditlog.collection_brief(cfg)
        result = graph.invoke({"brief": brief, "output": ""})
        return auditlog.extract_json(result["output"]) or {}

    summary = auditlog.run_auditlog_test(AGENT, generate)
    print(f"[{AGENT}] coverage_rate={summary['audit_log_coverage_rate_pct']}% "
          f"correctness={summary['audit_correctness_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
