#!/usr/bin/env python3
"""CrewAI webhook-delivery testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-subject
Task. CrewAI routes the model through LiteLLM, so the local Ollama backend works via an
"ollama/<model>" string and claude-haiku via "anthropic/<model>". Deterministic
execution (local receiver, register/create POSTs, polling, HMAC verification),
recording, and emit are the shared harness's job (agents/common/webhook.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import webhook  # noqa: E402
from webhook_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API webhook-delivery testing agent",
        goal="Convert one resource subject's webhook-delivery contract into a single JSON webhook test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = webhook.subject_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the nine webhook-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return webhook.extract_json(str(out)) or {}

    summary = webhook.run_webhook_test(AGENT, generate)
    print(f"[{AGENT}] contract_correctness={summary['webhook_contract_correctness_rate_pct']}% "
          f"delivery_success={summary['webhook_delivery_success_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
