#!/usr/bin/env python3
"""CrewAI soft-delete-behavior agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-run Task.
CrewAI routes the model through LiteLLM, so the Claude backend works via an
"anthropic/<model>" string (and Ollama via "ollama/<model>"). Deterministic execution
(the case_count create->delete->verify lifecycles + direct DB query), recording, and
emit are the shared harness's job (agents/common/softdelete.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import softdelete  # noqa: E402
from softdelete_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    kind = spec["native"]["kind"]
    if kind == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    if kind == "openai-cli":
        # OpenAI-compatible shim over `claude -p` (claude.ai subscription); litellm openai/ path.
        os.environ.setdefault("OPENAI_API_KEY", "local-shim")
        return LLM(model=f"openai/{spec['native']['model']}",
                   base_url=spec["base_url"], api_key="local-shim", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API soft-delete-testing agent",
        goal="Convert one soft-delete-test brief into a single JSON soft-delete test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        b = softdelete.brief(cfg)
        task = Task(description=user_message(b), agent=worker,
                    expected_output="A single JSON object with the seven soft-delete-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return softdelete.extract_json(str(out)) or {}

    summary = softdelete.run_softdelete_test(AGENT, generate)
    print(f"[{AGENT}] correctness_rate={summary['soft_delete_correctness_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']} "
          f"cases_ok={summary['correct_cases']}/{summary['total_cases']}")


if __name__ == "__main__":
    main()
