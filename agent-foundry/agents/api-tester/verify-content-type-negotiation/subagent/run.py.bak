#!/usr/bin/env python3
"""Wrapper for the Claude Code subagent api-tester-verify-content-type-negotiation.

The agent itself is the real subagent artifact
api-tester-verify-content-type-negotiation.md (YAML frontmatter + the debate-gated
body). When the backend is claude-haiku/cloud, this wrapper drives it through the
`claude` CLI as a subagent. Under the air-gapped Ollama backend (no cloud access),
it executes the SAME subagent body through the local OpenAI-compatible endpoint, so
the agent stays measurable on the same footing as the other three. The shared
harness executes/records/emits.
"""
import json
import os
import re
import sys
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import cn  # noqa: E402
from cn_prompt import user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "api-tester-verify-content-type-negotiation"
SPEC = backend_config.resolve(WS)
SUBAGENT_MD = Path(__file__).resolve().parent / "api-tester-verify-content-type-negotiation.md"


def _system_prompt() -> str:
    """The gated body of the subagent file (frontmatter stripped). The SkillOpt
    gate may override via FORGE_SKILL_DOC to evaluate a candidate skill without
    touching the artifact."""
    doc = os.environ.get("FORGE_SKILL_DOC")
    if doc and Path(doc).exists():
        return Path(doc).read_text().strip()
    text = SUBAGENT_MD.read_text()
    body = re.sub(r"^---\n.*?\n---\n", "", text, count=1, flags=re.DOTALL)
    return body.strip()


def _via_claude_cli(system: str, brief: str) -> str | None:
    """Drive the Claude Code subagent via the `claude` CLI. Runs under both the
    native-API ('anthropic') and subscription-shim ('openai-cli') backends. Under
    'openai-cli' the ANTHROPIC_API_KEY (out of credits) is unset so the CLI uses the
    claude.ai subscription."""
    kind = SPEC["native"]["kind"]
    if kind not in ("anthropic", "openai-cli") or not shutil.which("claude"):
        return None
    env = dict(os.environ)
    if kind == "openai-cli":
        env.pop("ANTHROPIC_API_KEY", None)
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{system}\n\n{user_message(brief)}", "--output-format", "text",
             "--model", SPEC["native"]["model"]],
            cwd=str(WS), stdin=subprocess.DEVNULL, capture_output=True, text=True,
            env=env, timeout=180)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _via_anthropic_sdk(system: str, brief: str) -> str | None:
    """Run the SAME gated subagent body through the Anthropic Messages API when the
    `claude` CLI is unavailable or fails (still the subagent's exact instructions,
    just a robust transport — never the dead local proxy). Uses ANTHROPIC_API_KEY."""
    if SPEC["native"]["kind"] != "anthropic":
        return None
    try:
        import anthropic
        client = anthropic.Anthropic()
        msg = client.messages.create(
            model=SPEC["native"]["model"], max_tokens=1024, temperature=0,
            system=system,
            messages=[{"role": "user", "content": user_message(brief)}])
        return "".join(b.text for b in msg.content if getattr(b, "type", None) == "text")
    except Exception:  # noqa
        return None


def _via_local(system: str, brief: str) -> str | None:
    try:
        body = json.dumps({
            "model": SPEC["model"], "temperature": 0,
            "messages": [{"role": "system", "content": system},
                         {"role": "user", "content": user_message(brief)}],
            "stream": False,
            "response_format": {"type": "json_object"},
        }).encode()
        req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                     headers={"Content-Type": "application/json"})
        with urllib.request.urlopen(req, timeout=300) as r:
            return json.loads(r.read())["choices"][0]["message"]["content"]
    except Exception:  # noqa
        return None


def main():
    system = _system_prompt()

    def generate(cfg: dict) -> dict:
        brief = cn.endpoint_brief(cfg)
        # primary: the Claude Code subagent via the `claude` CLI; robust fallbacks:
        # the Anthropic SDK (same body), then the local OpenAI-compatible path.
        out = (_via_claude_cli(system, brief)
               or _via_anthropic_sdk(system, brief)
               or _via_local(system, brief))
        return cn.extract_json(out) or {}

    summary = cn.run_cn_test(AGENT, generate)
    print(f"[{AGENT}] negotiation_accuracy={summary['content_type_negotiation_accuracy_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
