#!/usr/bin/env python3
"""CrewAI concurrent-request-handling agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-run Task.
CrewAI routes the model through LiteLLM, so the Claude backend works via an
"anthropic/<model>" string (and Ollama via "ollama/<model>"). Deterministic execution
(the 50+50 simultaneous requests + direct DB query), recording, and emit are the
shared harness's job (agents/common/concurrency.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import concurrency  # noqa: E402
from concurrency_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API concurrency-testing agent",
        goal="Convert one concurrency-test brief into a single JSON concurrent-request test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        b = concurrency.brief(cfg)
        task = Task(description=user_message(b), agent=worker,
                    expected_output="A single JSON object with the three concurrency-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return concurrency.extract_json(str(out)) or {}

    summary = concurrency.run_concurrency_test(AGENT, generate)
    print(f"[{AGENT}] success_rate={summary['concurrent_request_success_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']} "
          f"db_delta={summary['db_count_delta']}")


if __name__ == "__main__":
    main()
