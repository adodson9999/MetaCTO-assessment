#!/usr/bin/env python3
"""Claude Agent SDK api-gateway-routing testing agent.

Standalone program mirroring the other three. Native Claude is used when the backend
is set to claude-haiku; under the default air-gapped Ollama backend the SDK's cloud
path is unavailable, so it falls back to the OpenAI-compatible local endpoint
(Ollama /v1). Either way it elicits the routing test plan; the shared harness sends it
to the local gateway, queries each backend journal, and records/emits.
"""
import json
import os
import sys
import asyncio
import shutil
import subprocess
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import routing  # noqa: E402
from routing_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "claude_sdk"
APPROVED_PROMPT = active_prompt()
SPEC = backend_config.resolve(WS)


async def _native(brief: str) -> str:
    from claude_agent_sdk import query, ClaudeAgentOptions
    opts = ClaudeAgentOptions(system_prompt=APPROVED_PROMPT, model=SPEC["native"]["model"])
    chunks = []
    async for msg in query(prompt=user_message(brief), options=opts):
        chunks.append(getattr(msg, "content", str(msg)))
    return "".join(map(str, chunks))


def _anthropic_messages(brief: str) -> str:
    """Direct Anthropic Messages API — the same path langchain_anthropic/CrewAI use.
    Reached when the claude_agent_sdk runtime is unavailable (e.g. its Claude Code
    runtime errors) but the Messages API is usable."""
    import anthropic
    client = anthropic.Anthropic()
    msg = client.messages.create(
        model=SPEC["native"]["model"], max_tokens=1024, temperature=0,
        system=APPROVED_PROMPT,
        messages=[{"role": "user", "content": user_message(brief)}])
    return "".join(b.text for b in msg.content if getattr(b, "type", None) == "text")


def _via_claude_cli(brief: str) -> str | None:
    """Subscription-billed `claude` CLI fallback — keeps the agent measurable on Claude
    when the API-key paths are unavailable (e.g. API credit exhausted). Mirrors how the
    Claude Code subagent elicits."""
    if not shutil.which("claude"):
        return None
    try:
        proc = subprocess.run(
            ["claude", "-p", f"{APPROVED_PROMPT}\n\n{user_message(brief)}", "--output-format", "text"],
            cwd=str(WS), capture_output=True, text=True, timeout=180)
        return proc.stdout if proc.returncode == 0 else None
    except Exception:  # noqa
        return None


def _openai_compat(brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": APPROVED_PROMPT},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    return data["choices"][0]["message"]["content"]


def _has_json(text: str | None) -> bool:
    from routing import extract_json
    return bool(text) and extract_json(text) is not None


def _elicit(brief: str) -> str:
    """Elicit the plan through the Claude Agent SDK, with measurability fallbacks that
    stay on Claude: native SDK -> Anthropic Messages API -> `claude` CLI (subscription)
    -> local OpenAI-compatible shim. The first path that yields parseable JSON wins."""
    if SPEC["native"]["kind"] == "anthropic":
        try:
            out = asyncio.run(_native(brief))
            if _has_json(out):
                return out
        except Exception:  # noqa  -- SDK runtime unavailable/uncredited
            pass
        try:
            out = _anthropic_messages(brief)
            if _has_json(out):
                return out
        except Exception:  # noqa  -- Messages API unavailable/uncredited
            pass
        cli = _via_claude_cli(brief)
        if _has_json(cli):
            return cli
    return _openai_compat(brief)


def main():
    def generate(cfg: dict) -> dict:
        brief = routing.route_brief(cfg)
        return routing.extract_json(_elicit(brief)) or {}

    summary = routing.run_routing_test(AGENT, generate)
    print(f"[{AGENT}] route_forwarding_accuracy={summary['route_forwarding_accuracy_pct']}% "
          f"routes={summary['routes_forwarded']}/{summary['routes_total']}")


if __name__ == "__main__":
    main()
