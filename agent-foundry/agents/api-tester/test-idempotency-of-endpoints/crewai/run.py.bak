#!/usr/bin/env python3
"""CrewAI idempotency-testing agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-
collection Task. CrewAI routes the model through LiteLLM (anthropic/<model> for the
Claude backend, ollama/<model> for the local one). Deterministic execution (the real
replayed writes, byte capture, state probes), recording, and emit are the shared
harness's job (agents/common/idempotency.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import idempotency  # noqa: E402
from idempotency_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API idempotency-testing agent",
        goal="Convert one collection's idempotency contract into a single JSON idempotency test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = idempotency.collection_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the five idempotency-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        return idempotency.extract_json(str(out)) or {}

    summary = idempotency.run_idempotency_test(AGENT, generate)
    print(f"[{AGENT}] compliance_rate={summary['idempotency_compliance_rate_pct']}% "
          f"correctness={summary['idempotency_correctness_rate_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
