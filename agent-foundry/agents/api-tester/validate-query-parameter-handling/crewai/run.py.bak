#!/usr/bin/env python3
"""CrewAI query-parameter-handling agent.

One CrewAI Agent (role/goal/backstory carry the gated prompt) handles a per-
collection Task. CrewAI routes the model through LiteLLM, so claude-haiku works via
an "anthropic/<model>" string and the local Ollama backend via "ollama/<model>".
Deterministic execution (read-only GETs), recording, and emit are the shared
harness's job (agents/common/queryparam.py).
"""
import os
import sys
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import queryparam  # noqa: E402
from queryparam_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "crewai"
APPROVED_PROMPT = active_prompt()
TOTALS = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}


def _add_usage(metrics) -> None:
    """Accumulate token usage from crew.usage_metrics (best-effort across versions)."""
    if metrics is None:
        return
    g = (lambda k: getattr(metrics, k, None) if not isinstance(metrics, dict) else metrics.get(k))
    TOTALS["prompt_tokens"] += int(g("prompt_tokens") or 0)
    TOTALS["completion_tokens"] += int(g("completion_tokens") or 0)
    TOTALS["total_tokens"] += int(g("total_tokens") or 0)


def _llm():
    spec = backend_config.resolve(WS)
    from crewai import LLM
    if spec["native"]["kind"] == "anthropic":
        return LLM(model=f"anthropic/{spec['native']['model']}", temperature=0)
    return LLM(model=f"ollama/{spec['native']['model']}",
               base_url=spec["base_url"].replace("/v1", ""), temperature=0,
               response_format={"type": "json_object"})


def _build_agent():
    from crewai import Agent
    return Agent(
        role="API query-parameter-testing agent",
        goal="Convert one collection's documented query-parameter contract into a single JSON query-parameter test plan.",
        backstory=APPROVED_PROMPT,
        llm=_llm(), verbose=False, allow_delegation=False,
    )


def main():
    from crewai import Task, Crew
    worker = _build_agent()

    def generate(cfg: dict) -> dict:
        brief = queryparam.collection_brief(cfg)
        task = Task(description=user_message(brief), agent=worker,
                    expected_output="A single JSON object with the five query-parameter-plan keys.")
        crew = Crew(agents=[worker], tasks=[task], verbose=False)
        out = crew.kickoff()
        _add_usage(getattr(crew, "usage_metrics", None))
        return queryparam.extract_json(str(out)) or {}

    summary = queryparam.run_queryparam_test(AGENT, generate, usage=lambda: TOTALS)
    print(f"[{AGENT}] accuracy={summary['query_param_handling_accuracy_pct']}% "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']} "
          f"tokens={summary['tokens']['total_tokens']}")


if __name__ == "__main__":
    main()
