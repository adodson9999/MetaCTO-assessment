#!/usr/bin/env python3
"""Claude Agent SDK Retry-After-compliance testing agent.

Standalone program mirroring the other three. Native Claude is used when the backend
is set to claude-haiku; under the air-gapped Ollama backend the SDK's cloud path is
unavailable, so it falls back to the OpenAI-compatible local endpoint (Ollama /v1).
Either way it elicits the Retry-After test plan; the shared harness executes it with
read-only GETs at real timing (Retry-After parsing, deadline-anchored probes) and
records/emits.
"""
import json
import os
import sys
import asyncio
import urllib.request
from pathlib import Path

WS = Path(os.environ.get("FORGE_WORKSPACE", Path(__file__).resolve().parents[3]))
sys.path.insert(0, str(WS / "agents" / "common"))
sys.path.insert(0, str(WS / "scripts"))

import retryafter  # noqa: E402
from retryafter_prompt import active_prompt, user_message  # noqa: E402
import backend_config  # noqa: E402

AGENT = "claude_sdk"
APPROVED_PROMPT = active_prompt()
SPEC = backend_config.resolve(WS)


async def _native(brief: str) -> str:
    # No tools: this agent is a pure plan generator (sandbox parity with the other
    # three), so it never reads/writes/execs — it only emits JSON text.
    from claude_agent_sdk import query, ClaudeAgentOptions
    opts = ClaudeAgentOptions(system_prompt=APPROVED_PROMPT, model=SPEC["native"]["model"],
                              allowed_tools=[])
    text = []
    async for msg in query(prompt=user_message(brief), options=opts):
        content = getattr(msg, "content", None)
        if isinstance(content, list):
            # AssistantMessage.content is a list of typed blocks; collect TextBlock.text
            # (skip ThinkingBlock/ToolUseBlock, which carry no answer text).
            for block in content:
                t = getattr(block, "text", None)
                if isinstance(t, str):
                    text.append(t)
        elif isinstance(content, str):
            text.append(content)
    return "".join(text)


def _openai_compat(brief: str) -> str:
    body = json.dumps({
        "model": SPEC["model"], "temperature": 0,
        "messages": [{"role": "system", "content": APPROVED_PROMPT},
                     {"role": "user", "content": user_message(brief)}],
        "stream": False,
        "response_format": {"type": "json_object"},
    }).encode()
    req = urllib.request.Request(SPEC["base_url"] + "/chat/completions", data=body,
                                 headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=300) as r:
        data = json.loads(r.read())
    return data["choices"][0]["message"]["content"]


def _elicit(brief: str) -> str:
    if SPEC["native"]["kind"] == "anthropic":
        try:
            return asyncio.run(_native(brief))
        except Exception:  # noqa  -- cloud path unavailable air-gapped
            pass
    return _openai_compat(brief)


def main():
    def generate(cfg: dict) -> dict:
        brief = retryafter.endpoint_brief(cfg)
        return retryafter.extract_json(_elicit(brief)) or {}

    summary = retryafter.run_retryafter_test(AGENT, generate)
    print(f"[{AGENT}] retry_after_accuracy={summary['retry_after_accuracy_pct']}% "
          f"honored={summary['endpoints_honored']}/{summary['endpoints_total']} "
          f"enforced={summary['rate_limit_enforced']} "
          f"scenarios={summary['scenarios_api_correct']}/{summary['scenarios_total']}")


if __name__ == "__main__":
    main()
