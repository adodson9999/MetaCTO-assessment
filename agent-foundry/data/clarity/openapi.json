                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "maxLength": 40
                  },
                  "password": {
                    "type": "string",
                    "maxLength": 60
                  }
                },
                "required": [
                  "username",
                  "password"
                ],
                "additionalProperties": false
              },
