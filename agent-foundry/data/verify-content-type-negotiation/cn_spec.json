{
  "title": "Content-type-negotiation endpoint catalogue (authored for the task)",
  "description": "Agents are briefed one endpoint at a time. 'accept' endpoints get Accept-header response-negotiation probes; 'consumes' endpoints get request Content-Type probes. DummyJSON is never modified \u2014 read-only GETs for accept, non-persistent simulated writes for consumes.",
  "target": "http://localhost:8899",
  "supported_formats": [
    "application/json",
    "application/xml",
    "text/csv"
  ],
  "default_format": "application/json",
  "unsupported_accept_probe": "text/html",
  "wildcard_probe": "*/*",
  "supported_content_type": "application/json",
  "unsupported_content_type_probes": [
    "application/xml",
    "text/plain"
  ],
