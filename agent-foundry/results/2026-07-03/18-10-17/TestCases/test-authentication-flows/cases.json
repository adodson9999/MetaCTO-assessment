        "username": "emilys",
        "password": "wrong-password"
      },
      "auth": null
    },
    "expected_result": "status in [400, 401]; body has 'message'.",
    "actual_result": "HTTP 400. message='Invalid credentials'",
    "status": "Pass"
  },
